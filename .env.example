# Copy this file to .env and fill in real values.
# All variables have defaults — .env is optional for local development.

# ── Camera ────────────────────────────────────────────────────────────────────
RTSP_URL=rtsp://camera:password@192.168.0.213:554/stream1

# ── Live detection ────────────────────────────────────────────────────────────
LIVE_INTERVAL=1.0
LIVE_THRESHOLD=0.6
# Optional: POST JSON detections to this URL (leave empty to disable)
WEBHOOK_URL=

# ── Passwords ─────────────────────────────────────────────────────────────────
AIRFLOW_ADMIN_PASSWORD=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Service URLs (override when running scripts outside Docker) ───────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
VM_URL=http://victoriametrics:8428

# ── ffmpeg filesystem permissions ─────────────────────────────────────────────
PUID=1000
PGID=1000

# ── VictoriaMetrics ───────────────────────────────────────────────────────────
VM_RETENTION=365d
